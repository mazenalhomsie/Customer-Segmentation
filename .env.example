# ---------------------------------------------------------------------
# TravelTide Customer Segmentation - Environment Variables Example
# ---------------------------------------------------------------------

# Database Connection String
# Format: postgresql://[user]:[password]@[host]:[port]/[db_name]

DATABASE_URL=postgresql://my_username:my_secure_password@localhost:5432/traveltide_db

# Hinweis für Prüfer/Entwickler:
# Kopiere diese Datei, benenne sie in '.env' um und trage deine echten Datenbank-Zugangsdaten ein.
# Die '.env'Datei wird von git ignoriert, damit keine echten Passwörter im Repository landen!
